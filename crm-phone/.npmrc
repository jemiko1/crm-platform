# Electron packaging needs a flat node_modules tree so `electron-builder`
# can statically walk and copy transitive dependencies. Without this,
# `builder-util-runtime` (a transitive of `electron-updater`) ends up
# under `.pnpm/...` instead of top-level `node_modules/` and is then
# dropped from the bundled asar — which breaks the auto-updater with
# `(0, builder_util_runtime_1.retry) is not a function` at runtime.
#
# See: https://github.com/electron-userland/electron-builder/issues/6933
shamefully-hoist=true
