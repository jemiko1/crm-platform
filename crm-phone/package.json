{
  "name": "crm28-phone",
  "version": "1.10.2",
  "description": "CRM28 Desktop Softphone",
  "main": "dist/main/index.js",
  "packageManager": "pnpm@10.27.0",
  "author": "ASG",
  "repository": {
    "type": "git",
    "url": "https://github.com/jemiko1/crm-platform.git"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:main\" \"pnpm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --external:electron --external:electron-updater --external:electron-store --format=cjs --sourcemap",
    "build:preload": "esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/main/preload.js --external:electron --format=cjs --sourcemap",
    "build:renderer": "vite build",
    "build": "pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "start": "electron dist/main/index.js",
    "pack": "pnpm run build && electron-builder --win",
    "release": "pnpm run build && electron-builder --win --publish always",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "express": "^4.18.0",
    "sip.js": "^0.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "esbuild": "^0.27.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "builder-util-runtime": "9.5.1",
      "fs-extra": "^10.1.0",
      "js-yaml": "^4.1.0",
      "semver": "~7.7.3",
      "lazy-val": "^1.0.5"
    }
  }
}
