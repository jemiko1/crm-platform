# ══════════════════════════════════════════════════════════
#  Core Sync Bridge Configuration
#  Copy this file to .env and fill in real values
#
#  ⛔ ABSOLUTE RULE: This bridge ONLY READS from core MySQL.
#  NEVER write, update, delete, or alter anything in the
#  core database. Violation can halt company operations.
# ══════════════════════════════════════════════════════════

# ── Core MySQL (READ-ONLY!) ──────────────────────────────
CORE_MYSQL_HOST=192.168.65.97
CORE_MYSQL_PORT=3306
CORE_MYSQL_USER=asg_tablau
CORE_MYSQL_PASSWORD=change-me
CORE_MYSQL_DATABASE=asg_db

# ── CRM Backend ──────────────────────────────────────────
CRM_WEBHOOK_URL=https://api-crm28.asg.ge/v1/integrations/core/webhook
CRM_WEBHOOK_SECRET=change-me-must-match-crm-env

# HTTP settings
# CRM_TIMEOUT_MS=30000
# CRM_RETRY_ATTEMPTS=3
# CRM_RETRY_BASE_MS=1000

# ── Polling Schedule ─────────────────────────────────────
# POLL_INTERVAL_MINUTES=5
# COUNT_CHECK_INTERVAL_MINUTES=60
# NIGHTLY_REPAIR_HOUR=3

# ── Bulk Load Settings ───────────────────────────────────
# BULK_BATCH_SIZE=50
# BULK_BATCH_PAUSE_MS=2000

# ── Logging ──────────────────────────────────────────────
# LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARN, ERROR
