# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_dev"

# JWT authentication
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="15m"

# Optional overrides
# PORT=3000
# COOKIE_NAME=access_token
# COOKIE_SECURE=false   # use true on HTTPS in production (NODE_ENV=production)

# Seed admin account (used by prisma/seed.ts)
# SEED_ADMIN_EMAIL=admin@crm.local
# SEED_ADMIN_PASSWORD=Admin123!

# Client Chats – Viber Bot
# VIBER_BOT_TOKEN=""

# Client Chats – Facebook Messenger
# FB_PAGE_ACCESS_TOKEN=""
# FB_APP_SECRET=""
# FB_VERIFY_TOKEN=""

# Client Chats – Telegram Bot
# TELEGRAM_BOT_TOKEN=""

# Client Chats – WhatsApp Business (Cloud API)
# WA_ACCESS_TOKEN=""
# WA_PHONE_NUMBER_ID=""
# WA_VERIFY_TOKEN=""
# WA_APP_SECRET=""

# Client Chats – Webhook base URL (required for Telegram, Viber, webhook registration)
# Set to your backend's public URL, e.g. https://api.example.com
# CLIENTCHATS_WEBHOOK_BASE_URL=""

# Telephony / Call Center
TELEPHONY_INGEST_SECRET="change-me"

# Asterisk AMI (Manager Interface)
AMI_ENABLED="true"
AMI_HOST="127.0.0.1"
AMI_PORT="5038"
AMI_USER="crm"
AMI_SECRET="change-me"

# Asterisk ARI (REST Interface)
ARI_ENABLED="true"
ARI_BASE_URL="http://127.0.0.1:8088/ari"
ARI_USER="crm"
ARI_PASSWORD="change-me"

# After-hours queue names (comma-separated). Queues in this list get
# `isAfterHoursQueue=true` stamped on FIRST CREATE only (sticky — the 5-min
# sync never overwrites existing values). Calls to these queues produce
# MissedCall rows with reason=OUT_OF_HOURS. On the production VM, queue 40
# is the non-working-hours queue.
AFTER_HOURS_QUEUES="40,nowork"

# Company work-end hour (0-23, PROCESS LOCAL TIME). Used by
# OperatorBreakService.autoCloseStaleBreaks() cron — any active break
# started earlier that day is auto-closed at this hour with
# autoEndReason='company_hours_end'. A 12h hard cap also catches breaks
# that started after the end hour (e.g. 19:30).
#
# ⚠ Because this uses `Date.setHours()` which is process-local time,
# make sure `TZ` is also set correctly for each environment:
#   - Production VM: TZ=Asia/Tbilisi (matches business)
#   - Railway staging: set TZ=Asia/Tbilisi OR accept that the close
#     time is interpreted as UTC (19:00 UTC = 23:00 Tbilisi)
# If TZ is unset on the VM (Windows Server default), it uses the system
# locale which is usually correct — verify by checking the manager
# "Breaks" tab the day after a full-day cycle.
COMPANY_WORK_END_HOUR="19"
# TZ="Asia/Tbilisi"   # uncomment on Railway if needed

# CDR Import (from Asterisk CDR database)
# CDR_IMPORT_ENABLED="true"
# CDR_DB_URL="postgresql://asterisk:pass@localhost:5432/asteriskcdrdb"

# Recordings
# RECORDING_BASE_PATH="/var/spool/asterisk/monitor"

# OpenAI (Quality Review AI Pipeline)
# OPENAI_API_KEY="sk-..."
# QUALITY_AI_ENABLED="true"
# QUALITY_AI_MODEL="gpt-4o"
# QUALITY_AI_CRON="0 */2 * * * *"
