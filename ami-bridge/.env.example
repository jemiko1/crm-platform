# ══════════════════════════════════════════════════════════
#  AMI Bridge Configuration
#  Copy this file to .env and fill in real values
# ══════════════════════════════════════════════════════════

# ── Asterisk AMI Connection ──────────────────────────────
AMI_HOST=192.168.1.100
AMI_PORT=5038
AMI_USER=crm_ami
AMI_SECRET=change-me-strong-password

# Reconnect settings (milliseconds)
# AMI_RECONNECT_BASE_MS=2000
# AMI_RECONNECT_MAX_MS=60000
# AMI_PING_INTERVAL_MS=30000

# ── CRM Backend ──────────────────────────────────────────
CRM_BASE_URL=https://your-backend.up.railway.app
TELEPHONY_INGEST_SECRET=change-me-must-match-railway-env

# HTTP settings
# CRM_TIMEOUT_MS=15000
# CRM_RETRY_ATTEMPTS=3
# CRM_RETRY_BASE_MS=1000

# ── Event Batching ───────────────────────────────────────
# BUFFER_MAX_SIZE=20
# BUFFER_FLUSH_INTERVAL_MS=3000

# ── Logging ──────────────────────────────────────────────
# LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARN, ERROR
