# Database - Local PostgreSQL
DATABASE_URL=postgresql://postgres@localhost:5432/crm

# Auth — generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_EXPIRES_IN=30d

# Server
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://crm28.asg.ge,https://test.crm28.asg.ge
COOKIE_SECURE=true

# Webhooks
CLIENTCHATS_WEBHOOK_BASE_URL=https://crm28.asg.ge
CORE_WEBHOOK_SECRET=CHANGE_ME_MUST_MATCH_BRIDGE
TELEPHONY_INGEST_SECRET=CHANGE_ME_MUST_MATCH_AMI_BRIDGE
APP_BASE_URL=https://crm28.asg.ge

# Bug Reporter
ANTHROPIC_API_KEY=CHANGE_ME
GITHUB_TOKEN=CHANGE_ME
GITHUB_OWNER=jemiko1
GITHUB_REPO=CRM-Platform
BUG_REPORT_CLEANUP_SECRET=CHANGE_ME
NEXT_PUBLIC_BUG_REPORTER_ENABLED=true

# Telephony - Direct local access (no VPN needed)
AMI_ENABLED=true
