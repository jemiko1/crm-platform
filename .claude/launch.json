{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "CRM Backend (NestJS)",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm run start:dev"],
      "port": 3000,
      "cwd": "backend/crm-backend"
    },
    {
      "name": "CRM Frontend (Next.js)",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "pnpm dev --port 4002"],
      "port": 4002,
      "autoPort": false,
      "cwd": "frontend/crm-frontend"
    }
  ]
}
